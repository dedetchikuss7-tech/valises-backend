# App
PORT=3000
SWAGGER_ENABLED=true

# Security
JWT_SECRET=dev_jwt_secret_change_me

# CORS
# Example:
# CORS_ORIGINS=http://localhost:3001,http://localhost:5173
CORS_ORIGINS=

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/valises?schema=public"

# Storage
# Current implemented provider: MOCK_STORAGE
# Reserved future providers: S3, CLOUDINARY, SUPABASE, MANUAL
# Do not set S3/CLOUDINARY/SUPABASE/MANUAL in production until the provider is implemented.
STORAGE_PROVIDER=MOCK_STORAGE