generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  CREATED
  PAID
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum DisputeReasonCode {
  NOT_DELIVERED
  DAMAGED
  WRONG_ITEM
  WEIGHT_MISMATCH
  LATE_DELIVERY
  NO_SHOW_TRAVELER
  NO_SHOW_SENDER
  ILLEGAL_ITEM
  OTHER
}

enum EvidenceLevel {
  NONE
  BASIC
  STRONG
}

enum DisputeOutcome {
  REFUND_SENDER
  RELEASE_TO_TRAVELER
  SPLIT
  REJECT
}

enum LedgerEntryType {
  ESCROW_CREDIT


  // new debits
  ESCROW_DEBIT_RELEASE
  ESCROW_DEBIT_REFUND

  COMMISSION_ACCRUAL
  COMMISSION_REVERSAL
  RESERVE_CREDIT
  RESERVE_DEBIT
}

enum LedgerSource {
  PAYMENT
  RELEASE
  DISPUTE
  COMMISSION
  ADMIN
  SYSTEM
}

enum LedgerReferenceType {
  TRANSACTION
  DISPUTE
  PAYMENT
  OTHER
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(USER)

  kycStatus KycStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions   Transaction[]       @relation("SenderTransactions")
  travelTransactions Transaction[]       @relation("TravelerTransactions")
  disputesOpened     Dispute[]           @relation("UserDisputesOpened")
  disputesResolved   DisputeResolution[] @relation("AdminResolvedDisputes")
}

model Transaction {
  id String @id @default(uuid())

  senderId   String
  travelerId String

  amount       Int
  commission   Int @default(0)
  escrowAmount Int @default(0)

  status        TransactionStatus @default(CREATED)
  paymentStatus PaymentStatus     @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SenderTransactions", fields: [senderId], references: [id])
  traveler User @relation("TravelerTransactions", fields: [travelerId], references: [id])

  disputes      Dispute[]
  resolutions   DisputeResolution[]
  ledgerEntries LedgerEntry[]

  @@index([senderId])
  @@index([travelerId])
}

model Dispute {
  id String @id @default(uuid())

  transactionId String
  openedById    String

  reason     String
  reasonCode DisputeReasonCode @default(OTHER)
  status     DisputeStatus     @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  openedBy    User        @relation("UserDisputesOpened", fields: [openedById], references: [id])

  resolution DisputeResolution?

  @@index([transactionId])
  @@index([openedById])
  @@index([status])
}

model DisputeResolution {
  id            String @id @default(uuid())
  disputeId     String @unique
  transactionId String

  outcome       DisputeOutcome
  evidenceLevel EvidenceLevel  @default(NONE)

  // amounts in cents/units (same as Transaction.amount)
  refundAmount  Int @default(0)
  releaseAmount Int @default(0)

  decidedById String
  decidedAt   DateTime @default(now())

  notes               String?
  matrixVersion       String          @default("v1")
  recommendedOutcome  DisputeOutcome?
  recommendationNotes String?

  // ✅ idempotency (si on rappelle resolve)
  idempotencyKey String @unique

  dispute     Dispute     @relation(fields: [disputeId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  decidedBy   User        @relation("AdminResolvedDisputes", fields: [decidedById], references: [id])

  @@index([transactionId])
  @@index([outcome])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String
  type          LedgerEntryType
  amount        Int
  currency      String          @default("EUR")
  note          String?

  idempotencyKey String?

  // ✅ audit fields
  source        LedgerSource        @default(SYSTEM)
  referenceType LedgerReferenceType @default(TRANSACTION)
  referenceId   String?
  actorUserId   String?

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@unique([transactionId, idempotencyKey])
  @@index([transactionId])
  @@index([type])

  // optional but useful
  @@index([source])
  @@index([referenceType])
}
