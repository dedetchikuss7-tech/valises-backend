generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum KycProvider {
  STRIPE_IDENTITY
}

enum KycVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  CANCELED
}

enum TransactionStatus {
  CREATED
  PAID
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum DisputeReasonCode {
  NOT_DELIVERED
  DAMAGED
  WRONG_ITEM
  WEIGHT_MISMATCH
  LATE_DELIVERY
  NO_SHOW_TRAVELER
  NO_SHOW_SENDER
  ILLEGAL_ITEM
  OTHER
}

enum DisputeOpeningSource {
  MANUAL
  POST_DEPARTURE_BLOCK_SENDER
  POST_DEPARTURE_BLOCK_TRAVELER
}

enum DisputeInitiatedBySide {
  SENDER
  TRAVELER
}

enum DisputeTriggeredByRole {
  USER
  ADMIN
}

enum DisputeEvidenceStatus {
  NOT_REVIEWED
  IN_REVIEW
  REVIEWED
}

enum DisputeEvidenceItemKind {
  PHOTO
  SCREENSHOT
  CHAT_EXPORT
  TICKET
  OTHER
}

enum DisputeEvidenceItemStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum EvidenceLevel {
  NONE
  BASIC
  STRONG
}

enum DisputeOutcome {
  REFUND_SENDER
  RELEASE_TO_TRAVELER
  SPLIT
  REJECT
}

enum LedgerEntryType {
  ESCROW_CREDIT
  ESCROW_DEBIT_RELEASE
  ESCROW_DEBIT_REFUND

  COMMISSION_ACCRUAL
  COMMISSION_REVERSAL
  RESERVE_CREDIT
  RESERVE_DEBIT
}

enum LedgerSource {
  PAYMENT
  RELEASE
  DISPUTE
  COMMISSION
  ADMIN
  SYSTEM
}

enum LedgerReferenceType {
  TRANSACTION
  DISPUTE
  PAYMENT
  OTHER
}

enum TripStatus {
  DRAFT
  ACTIVE
  CANCELLED
}

enum FlightTicketStatus {
  NOT_PROVIDED
  PROVIDED
  VERIFIED
  REJECTED
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  RESERVED
  CANCELLED
}

enum PackageContentCategory {
  DOCUMENTS
  CLOTHING
  FOOD
  ELECTRONICS
  COSMETICS
  MEDICINE
  PERSONAL_ITEMS
  OTHER
}

enum PackageContentComplianceStatus {
  NOT_DECLARED
  DECLARED_CLEAR
  DECLARED_SENSITIVE
  BLOCKED
}

enum AbandonmentKind {
  TRIP_DRAFT
  PACKAGE_DRAFT
  KYC_PENDING
  PAYMENT_PENDING
}

enum AbandonmentEventStatus {
  ACTIVE
  RESOLVED
  DISMISSED
  CANCELLED
}

enum ReminderJobStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderChannel {
  INTERNAL
  EMAIL
}

enum PayoutProvider {
  MANUAL
  MOCK_STRIPE
}

enum PayoutStatus {
  READY
  REQUESTED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum RefundProvider {
  MANUAL
  MOCK_STRIPE
}

enum RefundStatus {
  READY
  REQUESTED
  PROCESSING
  REFUNDED
  FAILED
  CANCELLED
}

enum MessageModerationEventKind {
  SANITIZED
  BLOCKED
}

enum CorridorPricingStatus {
  SOCLE
  SECONDARY
  FALLBACK
}

enum PricingSourceType {
  OBSERVED
  SIMILAR_INHERITED
  REGIONAL_TEMPLATE
  MANUAL_OVERRIDE
}

enum PricingConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum CurrencyCode {
  EUR
  USD
  CAD
  XAF
  XOF
  MAD
}

enum PaymentMethodType {
  CARD
  MOBILE_MONEY
  BANK_TRANSFER
}

enum PayoutMethodType {
  MOBILE_MONEY
  BANK_PAYOUT
  MANUAL_PAYOUT
}

enum PaymentRailProvider {
  STRIPE
  CINETPAY
  FLUTTERWAVE
  PAYSTACK
  MANUAL
  BANK
}

model Corridor {
  id     String @id @default(uuid())
  code   String @unique
  name   String?
  status String @default("ACTIVE")

  trips        Trip[]
  packages     Package[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(USER)

  kycStatus KycStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions               Transaction[]         @relation("SenderTransactions")
  travelTransactions             Transaction[]         @relation("TravelerTransactions")
  disputesOpened                 Dispute[]             @relation("UserDisputesOpened")
  disputesResolved               DisputeResolution[]   @relation("AdminResolvedDisputes")
  disputeCaseNotesAuthored       DisputeCaseNote[]     @relation("AdminDisputeCaseNotes")
  reviewedDisputeEvidenceItems   DisputeEvidenceItem[] @relation("AdminReviewedDisputeEvidenceItems")

  trips                          Trip[]    @relation("UserTrips")
  packages                       Package[] @relation("UserPackages")
  verifiedTrips                  Trip[]    @relation("AdminVerifiedTrips")
  packageHandoversDeclared       Package[] @relation("PackageHandoverDeclaredBy")
  packageResponsibilityAcksGiven Package[] @relation("PackageTravelerResponsibilityAcknowledgedBy")
  packageContentsDeclared        Package[] @relation("PackageContentDeclaredBy")
  packageProhibitedAccepted      Package[] @relation("PackageProhibitedDeclarationAcceptedBy")

  messagesSent            Message[]                @relation("MessagesSent")
  abandonmentEvents       AbandonmentEvent[]
  messageModerationEvents MessageModerationEvent[]
  kycVerifications        KycVerification[]
}

model KycVerification {
  id                 String                @id @default(uuid())
  userId             String
  provider           KycProvider
  status             KycVerificationStatus @default(PENDING)
  providerSessionId  String                @unique
  providerStatus     String?
  providerSessionUrl String?
  failureReason      String?
  requestedAt        DateTime              @default(now())
  completedAt        DateTime?
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, provider])
}

model Trip {
  id         String @id @default(uuid())
  carrierId  String
  corridorId String

  departAt   DateTime
  capacityKg Float?

  status             TripStatus         @default(DRAFT)
  flightTicketStatus FlightTicketStatus @default(NOT_PROVIDED)

  verifiedAt   DateTime?
  verifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carrier    User     @relation("UserTrips", fields: [carrierId], references: [id])
  corridor   Corridor @relation(fields: [corridorId], references: [id])
  verifiedBy User?    @relation("AdminVerifiedTrips", fields: [verifiedById], references: [id])

  transactions      Transaction[]
  abandonmentEvents AbandonmentEvent[]

  @@index([carrierId])
  @@index([corridorId])
  @@index([status])
  @@index([flightTicketStatus])
}

model Package {
  id         String @id @default(uuid())
  senderId   String
  corridorId String

  weightKg    Float?
  description String?

  status PackageStatus @default(DRAFT)

  handoverDeclaredAt                     DateTime?
  handoverDeclaredById                   String?
  handoverNotes                          String?
  travelerResponsibilityAcknowledgedAt   DateTime?
  travelerResponsibilityAcknowledgedById String?

  contentCategory                       PackageContentCategory?
  contentSummary                        String?
  declaredItemCount                     Int?
  declaredValueAmount                   Decimal? @db.Decimal(12, 2)
  declaredValueCurrency                 CurrencyCode?
  containsFragileItems                  Boolean @default(false)
  containsLiquid                        Boolean @default(false)
  containsElectronic                    Boolean @default(false)
  containsBattery                       Boolean @default(false)
  containsMedicine                      Boolean @default(false)
  containsPerishableItems               Boolean @default(false)
  containsValuableItems                 Boolean @default(false)
  containsDocuments                     Boolean @default(false)
  containsProhibitedItems               Boolean @default(false)
  prohibitedItemsDeclarationAcceptedAt  DateTime?
  prohibitedItemsDeclarationAcceptedById String?
  contentDeclaredAt                     DateTime?
  contentDeclaredById                   String?
  contentComplianceStatus               PackageContentComplianceStatus @default(NOT_DECLARED)
  contentComplianceNotes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender                               User     @relation("UserPackages", fields: [senderId], references: [id])
  corridor                             Corridor @relation(fields: [corridorId], references: [id])
  handoverDeclaredBy                   User?    @relation("PackageHandoverDeclaredBy", fields: [handoverDeclaredById], references: [id])
  travelerResponsibilityAcknowledgedBy User?    @relation("PackageTravelerResponsibilityAcknowledgedBy", fields: [travelerResponsibilityAcknowledgedById], references: [id])
  contentDeclaredBy                    User?    @relation("PackageContentDeclaredBy", fields: [contentDeclaredById], references: [id])
  prohibitedItemsDeclarationAcceptedBy User?    @relation("PackageProhibitedDeclarationAcceptedBy", fields: [prohibitedItemsDeclarationAcceptedById], references: [id])

  transactions      Transaction[]
  abandonmentEvents AbandonmentEvent[]

  @@index([senderId])
  @@index([corridorId])
  @@index([status])
  @@index([handoverDeclaredAt])
  @@index([handoverDeclaredById])
  @@index([travelerResponsibilityAcknowledgedAt])
  @@index([travelerResponsibilityAcknowledgedById])
  @@index([contentDeclaredAt])
  @@index([contentDeclaredById])
  @@index([contentComplianceStatus])
  @@index([prohibitedItemsDeclarationAcceptedAt])
  @@index([prohibitedItemsDeclarationAcceptedById])
}

model Transaction {
  id String @id @default(uuid())

  senderId   String
  travelerId String

  tripId     String?
  packageId  String?
  corridorId String?

  amount       Int
  commission   Int    @default(0)
  escrowAmount Int    @default(0)
  currency     String @default("XAF")

  status        TransactionStatus @default(CREATED)
  paymentStatus PaymentStatus     @default(PENDING)

  payinRailProvider    PaymentRailProvider?
  payinMethodType      PaymentMethodType?
  payinProviderReference String?
  paymentConfirmedAt   DateTime?
  paymentMetadata      Json?

  deliveryCodeHash        String?
  deliveryCodeSalt        String?
  deliveryCodeGeneratedAt DateTime?
  deliveryCodeExpiresAt   DateTime?
  deliveryCodeConsumedAt  DateTime?
  deliveryConfirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SenderTransactions", fields: [senderId], references: [id])
  traveler User @relation("TravelerTransactions", fields: [travelerId], references: [id])

  trip     Trip?     @relation(fields: [tripId], references: [id])
  package  Package?  @relation(fields: [packageId], references: [id])
  corridor Corridor? @relation(fields: [corridorId], references: [id])

  disputes                Dispute[]
  resolutions             DisputeResolution[]
  ledgerEntries           LedgerEntry[]
  conversation            Conversation?
  abandonmentEvents       AbandonmentEvent[]
  payout                  Payout?
  refund                  Refund?
  messageModerationEvents MessageModerationEvent[]

  @@index([senderId])
  @@index([travelerId])
  @@index([tripId])
  @@index([packageId])
  @@index([corridorId])
  @@index([deliveryCodeExpiresAt])
  @@index([payinRailProvider])
  @@index([paymentConfirmedAt])
}

model Dispute {
  id String @id @default(uuid())

  transactionId String
  openedById    String

  reason            String
  reasonCode        DisputeReasonCode      @default(OTHER)
  openingSource     DisputeOpeningSource   @default(MANUAL)
  initiatedBySide   DisputeInitiatedBySide @default(SENDER)
  triggeredByRole   DisputeTriggeredByRole @default(USER)
  customerStatement String?
  travelerStatement String?
  evidenceSummary   String?
  adminAssessment   String?
  evidenceStatus    DisputeEvidenceStatus @default(NOT_REVIEWED)
  status            DisputeStatus         @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  openedBy    User        @relation("UserDisputesOpened", fields: [openedById], references: [id])

  resolution    DisputeResolution?
  caseNotes     DisputeCaseNote[]
  evidenceItems DisputeEvidenceItem[]

  @@index([transactionId])
  @@index([openedById])
  @@index([status])
  @@index([openingSource])
  @@index([initiatedBySide])
  @@index([triggeredByRole])
  @@index([evidenceStatus])
}

model DisputeEvidenceItem {
  id                String                     @id @default(uuid())
  disputeId         String
  kind              DisputeEvidenceItemKind
  label             String
  storageKey        String
  fileName          String?
  mimeType          String?
  sizeBytes         Int?
  status            DisputeEvidenceItemStatus @default(PENDING)
  reviewedByAdminId String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  dispute         Dispute @relation(fields: [disputeId], references: [id])
  reviewedByAdmin User?   @relation("AdminReviewedDisputeEvidenceItems", fields: [reviewedByAdminId], references: [id])

  @@index([disputeId])
  @@index([status])
  @@index([kind])
  @@index([reviewedByAdminId])
  @@index([createdAt])
}

model DisputeCaseNote {
  id            String   @id @default(uuid())
  disputeId     String
  authorAdminId String
  note          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dispute     Dispute @relation(fields: [disputeId], references: [id])
  authorAdmin User    @relation("AdminDisputeCaseNotes", fields: [authorAdminId], references: [id])

  @@index([disputeId])
  @@index([authorAdminId])
  @@index([createdAt])
}

model DisputeResolution {
  id            String @id @default(uuid())
  disputeId     String @unique
  transactionId String

  outcome       DisputeOutcome
  evidenceLevel EvidenceLevel @default(NONE)

  refundAmount  Int @default(0)
  releaseAmount Int @default(0)

  decidedById String
  decidedAt   DateTime @default(now())

  notes               String?
  matrixVersion       String         @default("v1")
  recommendedOutcome  DisputeOutcome?
  recommendationNotes String?

  idempotencyKey String @unique

  dispute     Dispute     @relation(fields: [disputeId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  decidedBy   User        @relation("AdminResolvedDisputes", fields: [decidedById], references: [id])

  @@index([transactionId])
  @@index([outcome])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String
  type          LedgerEntryType
  amount        Int
  currency      String          @default("XAF")
  note          String?

  idempotencyKey String?

  source        LedgerSource        @default(SYSTEM)
  referenceType LedgerReferenceType @default(TRANSACTION)
  referenceId   String?
  actorUserId   String?

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@unique([transactionId, idempotencyKey])
  @@index([transactionId])
  @@index([type])
  @@index([source])
  @@index([referenceType])
}

model Conversation {
  id            String   @id @default(uuid())
  transactionId String   @unique
  createdAt     DateTime @default(now())

  transaction      Transaction              @relation(fields: [transactionId], references: [id])
  messages         Message[]
  moderationEvents MessageModerationEvent[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRedacted     Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageModerationEvent {
  id             String                     @id @default(uuid())
  transactionId  String
  conversationId String
  senderId       String
  kind           MessageModerationEventKind
  code           String
  message        String
  reasons        Json?
  metadata       Json?
  createdAt      DateTime                   @default(now())

  transaction  Transaction  @relation(fields: [transactionId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([transactionId, createdAt])
  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([kind, code, createdAt])
}

model AbandonmentEvent {
  id     String                 @id @default(uuid())
  userId String
  kind   AbandonmentKind
  status AbandonmentEventStatus @default(ACTIVE)

  tripId        String?
  packageId     String?
  transactionId String?

  metadata Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  abandonedAt DateTime @default(now())
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  trip        Trip?        @relation(fields: [tripId], references: [id])
  package     Package?     @relation(fields: [packageId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  reminderJobs ReminderJob[]

  @@index([userId, kind, status])
  @@index([tripId])
  @@index([packageId])
  @@index([transactionId])
  @@index([abandonedAt])
}

model ReminderJob {
  id                 String            @id @default(uuid())
  abandonmentEventId String
  channel            ReminderChannel   @default(INTERNAL)
  status             ReminderJobStatus @default(PENDING)

  scheduledFor DateTime
  sentAt       DateTime?
  attemptCount Int      @default(0)
  lastError    String?

  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  abandonmentEvent AbandonmentEvent @relation(fields: [abandonmentEventId], references: [id])

  @@index([status, scheduledFor])
  @@index([abandonmentEventId])
}

model Payout {
  id                String         @id @default(uuid())
  transactionId     String         @unique
  provider          PayoutProvider @default(MANUAL)
  railProvider      PaymentRailProvider?
  payoutMethodType  PayoutMethodType?
  status            PayoutStatus   @default(READY)
  amount            Int
  currency          String         @default("XAF")
  idempotencyKey    String         @unique
  externalReference String?
  failureReason     String?
  metadata          Json?

  requestedAt DateTime?
  processedAt DateTime?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, provider])
  @@index([transactionId])
  @@index([railProvider])
  @@index([payoutMethodType])
}

model Refund {
  id                String         @id @default(uuid())
  transactionId     String         @unique
  provider          RefundProvider @default(MANUAL)
  status            RefundStatus   @default(READY)
  amount            Int
  currency          String         @default("XAF")
  idempotencyKey    String         @unique
  externalReference String?
  failureReason     String?
  metadata          Json?

  requestedAt DateTime?
  processedAt DateTime?
  refundedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, provider])
  @@index([transactionId])
}

model AdminActionAudit {
  id          String   @id @default(uuid())
  action      String
  targetType  String
  targetId    String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
}

model CorridorPricingPaymentConfig {
  id String @id @default(uuid())

  corridorCode           String @unique @map("corridor_code")
  originCountryCode      String @map("origin_country_code")
  destinationCountryCode String @map("destination_country_code")

  status                       CorridorPricingStatus  @map("status")
  pricingSourceType            PricingSourceType      @default(OBSERVED) @map("pricing_source_type")
  pricingCalibrationBasis      String?                @map("pricing_calibration_basis")
  pricingReferenceCorridorCode String?                @map("pricing_reference_corridor_code")
  confidenceLevel              PricingConfidenceLevel @default(MEDIUM) @map("confidence_level")

  isEstimated          Boolean @default(false) @map("is_estimated")
  requiresManualReview Boolean @default(false) @map("requires_manual_review")
  isVisible            Boolean @default(true) @map("is_visible")
  isBookable           Boolean @default(true) @map("is_bookable")

  settlementCurrency CurrencyCode @map("settlement_currency")

  terrainPricePerKg Decimal? @map("terrain_price_per_kg") @db.Decimal(12, 2)
  terrainBundle23kg Decimal? @map("terrain_bundle_23kg") @db.Decimal(12, 2)
  terrainBundle32kg Decimal? @map("terrain_bundle_32kg") @db.Decimal(12, 2)

  travelerGainPerKg Decimal? @map("traveler_gain_per_kg") @db.Decimal(12, 2)
  senderPricePerKg  Decimal? @map("sender_price_per_kg") @db.Decimal(12, 2)
  spreadPerKg       Decimal? @map("spread_per_kg") @db.Decimal(12, 2)

  travelerGainBundle23kg Decimal? @map("traveler_gain_bundle_23kg") @db.Decimal(12, 2)
  senderPriceBundle23kg  Decimal? @map("sender_price_bundle_23kg") @db.Decimal(12, 2)
  spreadBundle23kg       Decimal? @map("spread_bundle_23kg") @db.Decimal(12, 2)

  travelerGainBundle32kg Decimal? @map("traveler_gain_bundle_32kg") @db.Decimal(12, 2)
  senderPriceBundle32kg  Decimal? @map("sender_price_bundle_32kg") @db.Decimal(12, 2)
  spreadBundle32kg       Decimal? @map("spread_bundle_32kg") @db.Decimal(12, 2)

  payinMethodsAllowed  Json @default("[]") @map("payin_methods_allowed") @db.JsonB
  payoutMethodsAllowed Json @default("[]") @map("payout_methods_allowed") @db.JsonB

  payinPrimaryRail  PaymentRailProvider  @map("payin_primary_rail")
  payinBackupRail   PaymentRailProvider? @map("payin_backup_rail")
  payoutPrimaryRail PaymentRailProvider  @map("payout_primary_rail")
  payoutBackupRail  PaymentRailProvider? @map("payout_backup_rail")
  fallbackRail      PaymentRailProvider  @map("fallback_rail")

  isActive Boolean @default(true) @map("is_active")
  notes    String? @map("notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([originCountryCode, destinationCountryCode], map: "corridor_pricing_payment_config_origin_destination_idx")
  @@index([status], map: "corridor_pricing_payment_config_status_idx")
  @@index([pricingSourceType], map: "corridor_pricing_payment_config_pricing_source_type_idx")
  @@index([isVisible, isBookable], map: "corridor_pricing_payment_config_visibility_bookable_idx")
  @@map("corridor_pricing_payment_config")
}