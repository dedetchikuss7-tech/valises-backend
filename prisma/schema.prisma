generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  CREATED
  PAID
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)

  kycStatus KycStatus @default(NOT_STARTED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  sentTransactions   Transaction[] @relation("SenderTransactions")
  travelTransactions Transaction[] @relation("TravelerTransactions")
  disputesOpened     Dispute[]     @relation("UserDisputesOpened")
}

model Transaction {
  id            String            @id @default(uuid())

  senderId      String
  travelerId    String

  amount        Int
  commission    Int               @default(0)
  escrowAmount  Int               @default(0)

  status        TransactionStatus @default(CREATED)
  paymentStatus PaymentStatus     @default(PENDING)

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  sender        User @relation("SenderTransactions", fields: [senderId], references: [id])
  traveler      User @relation("TravelerTransactions", fields: [travelerId], references: [id])

  disputes      Dispute[]

  @@index([senderId])
  @@index([travelerId])
}

model Dispute {
  id            String        @id @default(uuid())

  transactionId String
  openedById    String

  reason        String
  status        DisputeStatus @default(OPEN)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transaction   Transaction   @relation(fields: [transactionId], references: [id])
  openedBy      User          @relation("UserDisputesOpened", fields: [openedById], references: [id])

  @@index([transactionId])
  @@index([openedById])
}