generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  CREATED
  PAID
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum DisputeReasonCode {
  NOT_DELIVERED
  DAMAGED
  WRONG_ITEM
  WEIGHT_MISMATCH
  LATE_DELIVERY
  NO_SHOW_TRAVELER
  NO_SHOW_SENDER
  ILLEGAL_ITEM
  OTHER
}

enum EvidenceLevel {
  NONE
  BASIC
  STRONG
}

enum DisputeOutcome {
  REFUND_SENDER
  RELEASE_TO_TRAVELER
  SPLIT
  REJECT
}

enum LedgerEntryType {
  ESCROW_CREDIT

  // new debits
  ESCROW_DEBIT_RELEASE
  ESCROW_DEBIT_REFUND

  COMMISSION_ACCRUAL
  COMMISSION_REVERSAL
  RESERVE_CREDIT
  RESERVE_DEBIT
}

enum LedgerSource {
  PAYMENT
  RELEASE
  DISPUTE
  COMMISSION
  ADMIN
  SYSTEM
}

enum LedgerReferenceType {
  TRANSACTION
  DISPUTE
  PAYMENT
  OTHER
}

//
// ✅ NEW: Trips / Packages
//
enum TripStatus {
  DRAFT
  ACTIVE
  CANCELLED
}

enum FlightTicketStatus {
  NOT_PROVIDED
  PROVIDED
  VERIFIED
  REJECTED
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  RESERVED
  CANCELLED
}

//
// ✅ NEW: Corridor (minimal V1)
// (pricing avancé plus tard)
//
model Corridor {
  id     String  @id @default(uuid())
  code   String  @unique // ex: "PARIS_DOUALA"
  name   String? // ex: "Paris → Douala"
  status String  @default("ACTIVE") // ACTIVE / PRELAUNCH / RESTRICTED (string V1 simple)

  trips        Trip[]
  packages     Package[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(USER)

  kycStatus KycStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions   Transaction[]       @relation("SenderTransactions")
  travelTransactions Transaction[]       @relation("TravelerTransactions")
  disputesOpened     Dispute[]           @relation("UserDisputesOpened")
  disputesResolved   DisputeResolution[] @relation("AdminResolvedDisputes")

  // ✅ NEW relations
  trips         Trip[]    @relation("UserTrips")
  packages      Package[] @relation("UserPackages")
  verifiedTrips Trip[]    @relation("AdminVerifiedTrips")
}

model Trip {
  id         String @id @default(uuid())
  carrierId  String
  corridorId String

  departAt   DateTime
  capacityKg Float?

  status             TripStatus         @default(DRAFT)
  flightTicketStatus FlightTicketStatus @default(NOT_PROVIDED)

  verifiedAt   DateTime?
  verifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  carrier    User     @relation("UserTrips", fields: [carrierId], references: [id])
  corridor   Corridor @relation(fields: [corridorId], references: [id])
  verifiedBy User?    @relation("AdminVerifiedTrips", fields: [verifiedById], references: [id])

  transactions Transaction[]

  @@index([carrierId])
  @@index([corridorId])
  @@index([status])
  @@index([flightTicketStatus])
}

model Package {
  id         String @id @default(uuid())
  senderId   String
  corridorId String

  weightKg    Float?
  description String?

  status PackageStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  sender   User     @relation("UserPackages", fields: [senderId], references: [id])
  corridor Corridor @relation(fields: [corridorId], references: [id])

  transactions Transaction[]

  @@index([senderId])
  @@index([corridorId])
  @@index([status])
}

model Transaction {
  id String @id @default(uuid())

  senderId   String
  travelerId String

  // ✅ NEW (V1): link to Trip/Package + corridor
  tripId     String?
  packageId  String?
  corridorId String?

  amount       Int
  commission   Int @default(0)
  escrowAmount Int @default(0)

  status        TransactionStatus @default(CREATED)
  paymentStatus PaymentStatus     @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SenderTransactions", fields: [senderId], references: [id])
  traveler User @relation("TravelerTransactions", fields: [travelerId], references: [id])

  // ✅ NEW relations
  trip     Trip?     @relation(fields: [tripId], references: [id])
  package  Package?  @relation(fields: [packageId], references: [id])
  corridor Corridor? @relation(fields: [corridorId], references: [id])

  disputes      Dispute[]
  resolutions   DisputeResolution[]
  ledgerEntries LedgerEntry[]

  @@index([senderId])
  @@index([travelerId])
  @@index([tripId])
  @@index([packageId])
  @@index([corridorId])
}

model Dispute {
  id String @id @default(uuid())

  transactionId String
  openedById    String

  reason     String
  reasonCode DisputeReasonCode @default(OTHER)
  status     DisputeStatus     @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  openedBy    User        @relation("UserDisputesOpened", fields: [openedById], references: [id])

  resolution DisputeResolution?

  @@index([transactionId])
  @@index([openedById])
  @@index([status])
}

model DisputeResolution {
  id            String @id @default(uuid())
  disputeId     String @unique
  transactionId String

  outcome       DisputeOutcome
  evidenceLevel EvidenceLevel  @default(NONE)

  // amounts in cents/units (same as Transaction.amount)
  refundAmount  Int @default(0)
  releaseAmount Int @default(0)

  decidedById String
  decidedAt   DateTime @default(now())

  notes               String?
  matrixVersion       String          @default("v1")
  recommendedOutcome  DisputeOutcome?
  recommendationNotes String?

  // ✅ idempotency (si on rappelle resolve)
  idempotencyKey String @unique

  dispute     Dispute     @relation(fields: [disputeId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  decidedBy   User        @relation("AdminResolvedDisputes", fields: [decidedById], references: [id])

  @@index([transactionId])
  @@index([outcome])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String
  type          LedgerEntryType
  amount        Int
  currency      String          @default("EUR")
  note          String?

  idempotencyKey String?

  // ✅ audit fields
  source        LedgerSource        @default(SYSTEM)
  referenceType LedgerReferenceType @default(TRANSACTION)
  referenceId   String?
  actorUserId   String?

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@unique([transactionId, idempotencyKey])
  @@index([transactionId])
  @@index([type])
  // optional but useful
  @@index([source])
  @@index([referenceType])
}
