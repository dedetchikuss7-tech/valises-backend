generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionStatus {
  CREATED
  PAID
  IN_TRANSIT
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum DisputeReasonCode {
  NOT_DELIVERED
  DAMAGED
  WRONG_ITEM
  WEIGHT_MISMATCH
  LATE_DELIVERY
  NO_SHOW_TRAVELER
  NO_SHOW_SENDER
  ILLEGAL_ITEM
  OTHER
}

enum EvidenceLevel {
  NONE
  BASIC
  STRONG
}

enum DisputeOutcome {
  REFUND_SENDER
  RELEASE_TO_TRAVELER
  SPLIT
  REJECT
}

enum LedgerEntryType {
  ESCROW_CREDIT
  ESCROW_DEBIT_RELEASE
  ESCROW_DEBIT_REFUND

  COMMISSION_ACCRUAL
  COMMISSION_REVERSAL
  RESERVE_CREDIT
  RESERVE_DEBIT
}

enum LedgerSource {
  PAYMENT
  RELEASE
  DISPUTE
  COMMISSION
  ADMIN
  SYSTEM
}

enum LedgerReferenceType {
  TRANSACTION
  DISPUTE
  PAYMENT
  OTHER
}

enum TripStatus {
  DRAFT
  ACTIVE
  CANCELLED
}

enum FlightTicketStatus {
  NOT_PROVIDED
  PROVIDED
  VERIFIED
  REJECTED
}

enum PackageStatus {
  DRAFT
  PUBLISHED
  RESERVED
  CANCELLED
}

enum AbandonmentKind {
  TRIP_DRAFT
  PACKAGE_DRAFT
  KYC_PENDING
  PAYMENT_PENDING
}

enum AbandonmentEventStatus {
  ACTIVE
  RESOLVED
  DISMISSED
  CANCELLED
}

enum ReminderJobStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ReminderChannel {
  INTERNAL
  EMAIL
}

enum PayoutProvider {
  MANUAL
  MOCK_STRIPE
}

enum PayoutStatus {
  READY
  REQUESTED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum RefundProvider {
  MANUAL
  MOCK_STRIPE
}

enum RefundStatus {
  READY
  REQUESTED
  PROCESSING
  REFUNDED
  FAILED
  CANCELLED
}

enum MessageModerationEventKind {
  SANITIZED
  BLOCKED
}

model Corridor {
  id     String @id @default(uuid())
  code   String @unique
  name   String?
  status String @default("ACTIVE")

  trips        Trip[]
  packages     Package[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(USER)

  kycStatus KycStatus @default(NOT_STARTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentTransactions   Transaction[]       @relation("SenderTransactions")
  travelTransactions Transaction[]       @relation("TravelerTransactions")
  disputesOpened     Dispute[]           @relation("UserDisputesOpened")
  disputesResolved   DisputeResolution[] @relation("AdminResolvedDisputes")

  trips         Trip[]    @relation("UserTrips")
  packages      Package[] @relation("UserPackages")
  verifiedTrips Trip[]    @relation("AdminVerifiedTrips")

  messagesSent            Message[]                @relation("MessagesSent")
  abandonmentEvents       AbandonmentEvent[]
  messageModerationEvents MessageModerationEvent[]
}

model Trip {
  id         String @id @default(uuid())
  carrierId  String
  corridorId String

  departAt   DateTime
  capacityKg Float?

  status             TripStatus         @default(DRAFT)
  flightTicketStatus FlightTicketStatus @default(NOT_PROVIDED)

  verifiedAt   DateTime?
  verifiedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carrier    User     @relation("UserTrips", fields: [carrierId], references: [id])
  corridor   Corridor @relation(fields: [corridorId], references: [id])
  verifiedBy User?    @relation("AdminVerifiedTrips", fields: [verifiedById], references: [id])

  transactions      Transaction[]
  abandonmentEvents AbandonmentEvent[]

  @@index([carrierId])
  @@index([corridorId])
  @@index([status])
  @@index([flightTicketStatus])
}

model Package {
  id         String @id @default(uuid())
  senderId   String
  corridorId String

  weightKg    Float?
  description String?

  status PackageStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User     @relation("UserPackages", fields: [senderId], references: [id])
  corridor Corridor @relation(fields: [corridorId], references: [id])

  transactions      Transaction[]
  abandonmentEvents AbandonmentEvent[]

  @@index([senderId])
  @@index([corridorId])
  @@index([status])
}

model Transaction {
  id String @id @default(uuid())

  senderId   String
  travelerId String

  tripId     String?
  packageId  String?
  corridorId String?

  amount       Int
  commission   Int @default(0)
  escrowAmount Int @default(0)

  status        TransactionStatus @default(CREATED)
  paymentStatus PaymentStatus     @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sender   User @relation("SenderTransactions", fields: [senderId], references: [id])
  traveler User @relation("TravelerTransactions", fields: [travelerId], references: [id])

  trip     Trip?     @relation(fields: [tripId], references: [id])
  package  Package?  @relation(fields: [packageId], references: [id])
  corridor Corridor? @relation(fields: [corridorId], references: [id])

  disputes                Dispute[]
  resolutions             DisputeResolution[]
  ledgerEntries           LedgerEntry[]
  conversation            Conversation?
  abandonmentEvents       AbandonmentEvent[]
  payout                  Payout?
  refund                  Refund?
  messageModerationEvents MessageModerationEvent[]

  @@index([senderId])
  @@index([travelerId])
  @@index([tripId])
  @@index([packageId])
  @@index([corridorId])
}

model Dispute {
  id String @id @default(uuid())

  transactionId String
  openedById    String

  reason     String
  reasonCode DisputeReasonCode @default(OTHER)
  status     DisputeStatus     @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])
  openedBy    User        @relation("UserDisputesOpened", fields: [openedById], references: [id])

  resolution DisputeResolution?

  @@index([transactionId])
  @@index([openedById])
  @@index([status])
}

model DisputeResolution {
  id            String @id @default(uuid())
  disputeId     String @unique
  transactionId String

  outcome       DisputeOutcome
  evidenceLevel EvidenceLevel @default(NONE)

  refundAmount  Int @default(0)
  releaseAmount Int @default(0)

  decidedById String
  decidedAt   DateTime @default(now())

  notes               String?
  matrixVersion       String          @default("v1")
  recommendedOutcome  DisputeOutcome?
  recommendationNotes String?

  idempotencyKey String @unique

  dispute     Dispute     @relation(fields: [disputeId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])
  decidedBy   User        @relation("AdminResolvedDisputes", fields: [decidedById], references: [id])

  @@index([transactionId])
  @@index([outcome])
}

model LedgerEntry {
  id            String          @id @default(uuid())
  transactionId String
  type          LedgerEntryType
  amount        Int
  currency      String          @default("EUR")
  note          String?

  idempotencyKey String?

  source        LedgerSource        @default(SYSTEM)
  referenceType LedgerReferenceType @default(TRANSACTION)
  referenceId   String?
  actorUserId   String?

  createdAt DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@unique([transactionId, idempotencyKey])
  @@index([transactionId])
  @@index([type])
  @@index([source])
  @@index([referenceType])
}

model Conversation {
  id            String   @id @default(uuid())
  transactionId String   @unique
  createdAt     DateTime @default(now())

  transaction      Transaction              @relation(fields: [transactionId], references: [id])
  messages         Message[]
  moderationEvents MessageModerationEvent[]
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRedacted     Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model MessageModerationEvent {
  id             String                     @id @default(uuid())
  transactionId  String
  conversationId String
  senderId       String
  kind           MessageModerationEventKind
  code           String
  message        String
  reasons        Json?
  metadata       Json?
  createdAt      DateTime                   @default(now())

  transaction  Transaction  @relation(fields: [transactionId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([transactionId, createdAt])
  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([kind, code, createdAt])
}

model AbandonmentEvent {
  id     String                 @id @default(uuid())
  userId String
  kind   AbandonmentKind
  status AbandonmentEventStatus @default(ACTIVE)

  tripId        String?
  packageId     String?
  transactionId String?

  metadata Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  abandonedAt DateTime @default(now())
  resolvedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id])
  trip        Trip?        @relation(fields: [tripId], references: [id])
  package     Package?     @relation(fields: [packageId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  reminderJobs ReminderJob[]

  @@index([userId, kind, status])
  @@index([tripId])
  @@index([packageId])
  @@index([transactionId])
  @@index([abandonedAt])
}

model ReminderJob {
  id                 String            @id @default(uuid())
  abandonmentEventId String
  channel            ReminderChannel   @default(INTERNAL)
  status             ReminderJobStatus @default(PENDING)

  scheduledFor DateTime
  sentAt       DateTime?
  attemptCount Int               @default(0)
  lastError    String?

  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  abandonmentEvent AbandonmentEvent @relation(fields: [abandonmentEventId], references: [id])

  @@index([status, scheduledFor])
  @@index([abandonmentEventId])
}

model Payout {
  id                String         @id @default(uuid())
  transactionId     String         @unique
  provider          PayoutProvider @default(MANUAL)
  status            PayoutStatus   @default(READY)
  amount            Int
  currency          String         @default("XAF")
  idempotencyKey    String         @unique
  externalReference String?
  failureReason     String?
  metadata          Json?

  requestedAt DateTime?
  processedAt DateTime?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, provider])
  @@index([transactionId])
}

model Refund {
  id                String         @id @default(uuid())
  transactionId     String         @unique
  provider          RefundProvider @default(MANUAL)
  status            RefundStatus   @default(READY)
  amount            Int
  currency          String         @default("XAF")
  idempotencyKey    String         @unique
  externalReference String?
  failureReason     String?
  metadata          Json?

  requestedAt DateTime?
  processedAt DateTime?
  refundedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([status, provider])
  @@index([transactionId])
}

model AdminActionAudit {
  id          String   @id @default(uuid())
  action      String
  targetType  String
  targetId    String
  actorUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorUserId, createdAt])
}